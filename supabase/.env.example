# Local Supabase CLI environment variables.
# Copy this file to `supabase/.env` and fill in real values.
# `supabase/.env` is gitignored by the CLI's default .gitignore.

# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID).
# Authorized redirect URI to register with Google for local dev:
#   http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
